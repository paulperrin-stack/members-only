<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <title>Members Only</title>
</head>
<body>
    <h1>Members Only Club</h1>

    <% if (user) { %>
        <p>Welcome, <%= user.first_name %>!</p>
        <a href="/new-message">Create a New Message</a>

        <% if (!user.member) { %>
            <a href="/join">Join the Club</a>
        <% } else { %>
            <p>✅ You are a member!</p>
        <% } %>

        <a href="/log-out">Log Out</a>
    <% } else { %>
        <a href="/log-in">Log In</a>
        <a href="/sign-up">Sign Up</a>
    <% } %>

    <hr>

    <h2>Messages</h2>

    <% if (messages.length === 0) { %>
        <p>No messages yet.</p>
    <% } else { %>
        <% messages.forEach(message => { %>
            <div style="border: 1px solid #ccc; padding: 10px; margin: 10px 0;">
                <h3><%= message.title %></h3>
                <p><%= message.text %></p>

                <%# Only members and admins can see author and date %>
                <% if (user && (user.member || user.is_admin)) { %>
                    <small>
                        Posted by <%= message.first_name %> <%= message.last_name %>
                        on <%= new Date(message.created_at).toLocaleDateString() %>
                    </small>
                <% } else { %>
                    <small>Author and date hidden — join the club to see!</small>
                <% } %>
            </div>
        <% }) %>
    <% } %>
</body>
</html>